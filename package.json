{
  "name": "aerovision-mvp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "next dev --turbopack",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "typecheck": "tsc --noEmit",
    "vercel:preview": "vercel",
    "vercel:prod": "vercel deploy --prod --yes",
    "vercel:env:pull": "vercel env pull .env.local",
    "vercel:pull:preview": "vercel pull --yes --environment=preview",
    "vercel:pull:production": "vercel pull --yes --environment=production",
    "vercel:build:preview": "vercel pull --yes --environment=preview && vercel build",
    "vercel:build:production": "vercel pull --yes --environment=production && vercel build --prod",
    "vercel:deploy:prebuilt": "vercel deploy --prebuilt",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:integration": "vitest run tests/unit/exception-engine.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test tests/e2e/public-pages.spec.ts",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "7.5.0",
    "@prisma/client": "7.5.0",
    "@vercel/blob": "^2.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "jsdom": "^28.1.0",
    "prisma": "7.5.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
