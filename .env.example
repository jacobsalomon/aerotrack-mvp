# AeroVision MVP — Environment Variables
# Copy this file to .env and fill in your values.

# Database — Neon Postgres (serverless)
# Get these from: https://console.neon.tech → your project → Connection Details
# Pooled connection (for the app — uses HTTP adapter)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Unpooled connection (for migrations only)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Dashboard passcode — protects the web dashboard
PASSCODE="2206"

# AI API keys — optional, mock data used when not set
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# GOOGLE_AI_API_KEY="..."

# Anthropic API configuration
# ANTHROPIC_API_BASE="https://api.anthropic.com"
# ANTHROPIC_API_VERSION="2023-06-01"

# Optional model pin overrides (fallback chains are defined in lib/ai/models.ts)
# OCR_MODEL="gpt-5.4"
# GENERATION_MODEL="gpt-5.4"
# VERIFICATION_MODEL="claude-sonnet-4-6-20250217"
# VIDEO_ANNOTATION_MODEL="gemini-3.1-flash"
# VIDEO_ANALYSIS_MODEL="gemini-3.1-pro-preview"
# TRANSCRIPTION_MODEL="gpt-4o-transcribe"

# Vercel Blob storage — for mobile evidence uploads
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."
