// AeroVision MVP Database Schema
// This defines all the data structures for tracking aerospace component lifecycles.
// Think of each "model" as a type of record in our system.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL configured in prisma.config.ts (Prisma 7 moved it out of schema)
}

// ══════════════════════════════════════════════════════
// AUTH.JS (NextAuth v5) MODELS
// These power OAuth login with Google and Microsoft Entra ID.
// The User model is Auth.js's identity and also holds technician profile data.
// ══════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?                          // bcrypt hash — set when user registers with email/password
  role          String    @default("USER")       // USER (single role — everyone has same access)

  // Fields consolidated from former Technician model
  organizationId       String?
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  firstName            String?
  lastName             String?
  badgeNumber          String?   @unique
  status               String    @default("ACTIVE")
  apiKey               String?   @unique
  faaLicenseNumber     String?
  faaLicenseType       String?
  faaLicenseVerifiedAt DateTime?

  accounts      Account[]
  sessions      Session[]

  // Relationships (moved from Technician)
  captureSessions     CaptureSession[]
  signedOffSessions   CaptureSession[]   @relation("inspectionSignOff")
  reviewedDocuments   CaptureDocument[]  @relation("reviewer")
  auditLog            AuditLogEntry[]
  createdTemplates    InspectionTemplate[]
  completedProgress   InspectionProgress[] @relation("progressCompletedBy")
  createdFindings     InspectionFinding[]  @relation("findingCreatedBy")

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────
// Password reset tokens — used for the "forgot password" flow.
// Each token is single-use and expires after 1 hour.
// ──────────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String                              // Email address the reset was requested for
  token     String   @unique                    // Random token sent in the reset link
  expiresAt DateTime                            // Token expires after 1 hour
  createdAt DateTime @default(now())

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────
// Electronic signatures for regulatory documents.
// Captures the signer's identity, the document hash at time of signing,
// and an optional signature image (base64 PNG from the signature pad).
// ──────────────────────────────────────────────────────
model Signature {
  id             String   @id @default(cuid())
  documentId     String            // References GeneratedDocument.id
  signerId       String            // User who signed
  signerName     String            // Display name of signer
  signerEmail    String?           // Email of signer
  signerRole     String            // "TECHNICIAN", "SUPERVISOR", "ADMIN"
  certificateRef String?           // FAA license number (A&P/IA)
  documentHash   String            // SHA-256 of document content at time of signing
  signatureImage String?           // Base64 PNG of drawn signature
  ipAddress      String?           // IP address at time of signing
  userAgent      String?           // Browser user agent string
  signedAt       DateTime @default(now())

  @@index([documentId])
  @@index([signerId])
}

// ──────────────────────────────────────────────────────
// A component — the core entity. One record per physical part.
// Example: A single Parker HPC-7 Hydraulic Pump, serial number SN-2019-07842
// ──────────────────────────────────────────────────────
model Component {
  id                  String   @id @default(cuid())
  partNumber          String                          // Real Parker format: "881700-1001"
  serialNumber        String   @unique                // e.g., "SN-2019-07842"
  description         String                          // e.g., "HPC-7 Hydraulic Pump"
  oem                 String                          // e.g., "Parker Aerospace"
  oemDivision         String?                         // e.g., "Hydraulic Systems Division"
  manufactureDate     DateTime
  manufacturePlant    String?                         // e.g., "Irvine, CA"
  totalHours          Float    @default(0)
  totalCycles         Int      @default(0)
  timeSinceOverhaul   Float?   @default(0)            // TSO — hours since last overhaul
  cyclesSinceOverhaul Int?     @default(0)            // CSO — cycles since last overhaul
  status              String   @default("serviceable") // serviceable, in-repair, installed, retired, quarantined
  currentLocation     String?                          // Where the part physically is right now
  currentAircraft     String?                          // Registration of aircraft it's installed on
  currentOperator     String?                          // Airline currently operating it
  isLifeLimited       Boolean  @default(false)         // Is this a life-limited part (LLP)?
  lifeLimit           Int?                             // If LLP, what's the cycle/hour limit?
  imageUrl            String?                          // Photo of the part
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relationships — one component has many events, alerts, and documents
  events       LifecycleEvent[]
  alerts       Alert[]
  documents    Document[]
  exceptions   Exception[]
  measurements Measurement[]
  inspectionTemplates ComponentInspectionTemplate[]
}

// ──────────────────────────────────────────────────────
// A single event in a component's life.
// Examples: manufacture, install on aircraft, remove for repair, overhaul steps, etc.
// ──────────────────────────────────────────────────────
model LifecycleEvent {
  id            String   @id @default(cuid())
  componentId   String
  component     Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  eventType     String    // "manufacture", "install", "remove", "receiving_inspection",
                          // "teardown", "detailed_inspection", "repair", "reassembly",
                          // "functional_test", "final_inspection", "release_to_service",
                          // "transfer", "retire", "scrap"
  date          DateTime
  facility      String    // Where this happened — e.g., "ST Engineering, Singapore"
  facilityType  String    // "oem", "airline", "mro", "distributor", "broker"
  facilityCert  String?   // FAA Part 145 certificate number
  performer     String    // Who did the work (company or person)
  performerCert String?   // Mechanic's certificate number (A&P, IA, etc.)
  description   String    // What happened — the narrative
  hoursAtEvent  Float?    // Component hours at time of event
  cyclesAtEvent Int?      // Component cycles at time of event
  aircraft      String?   // Aircraft registration (if applicable)
  operator      String?   // Airline (if applicable)
  workOrderRef  String?   // Work order or job card reference number
  cmmReference  String?   // Applicable CMM and revision
  notes         String?   // Additional observations (tribal knowledge!)
  hash          String?   // SHA-256 hash for tamper evidence
  createdAt     DateTime  @default(now())

  // Relationships
  evidence      Evidence[]
  generatedDocs GeneratedDocument[]
  partsConsumed PartConsumed[]

  @@index([componentId])
}

// ──────────────────────────────────────────────────────
// A piece of captured evidence — photo, voice note, measurement, document scan
// Attached to a specific lifecycle event
// ──────────────────────────────────────────────────────
model Evidence {
  id              String   @id @default(cuid())
  eventId         String
  event           LifecycleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type            String         // "photo", "video", "voice_note", "document_scan", "measurement"
  fileName        String
  filePath        String
  mimeType        String
  capturedAt      DateTime
  capturedBy      String         // User name
  capturedByBadge String?        // Badge number
  location        String?        // Facility name
  transcription   String?        // AI transcription of voice note
  structuredData  Json?          // AI-structured version (parsed JSON)
  hash            String         // SHA-256 hash for tamper evidence
  createdAt       DateTime       @default(now())

  @@index([eventId])
}

// ──────────────────────────────────────────────────────
// AI-generated formal documents — 8130-3, work orders, findings reports
// These are the paperwork that the AI writes automatically
// ──────────────────────────────────────────────────────
model GeneratedDocument {
  id           String    @id @default(cuid())
  eventId      String
  event        LifecycleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  docType      String         // "8130-3", "work_order", "findings_report", "test_results"
  title        String
  content      String         // Full generated document content (JSON)
  provenanceJson Json?        // JSON — per-field evidence provenance for the evidence-chain UI
  pdfPath      String?        // Path to generated PDF
  status       String    @default("draft") // "draft", "approved", "signed"
  approvedBy   String?        // Who approved/signed
  approvedAt   DateTime?
  signatureRef String?        // Electronic signature reference
  hash         String?        // Document hash
  createdAt    DateTime  @default(now())

  @@index([eventId])
}

// ──────────────────────────────────────────────────────
// Replacement parts consumed during a repair
// Creates nested traceability — the new part's own 8130-3 links here
// ──────────────────────────────────────────────────────
model PartConsumed {
  id           String   @id @default(cuid())
  eventId      String
  event        LifecycleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partNumber   String         // P/N of the consumed/replacement part
  serialNumber String?        // S/N if serialized
  description  String
  quantity     Int      @default(1)
  sourceDoc    String?        // 8130-3 or CoC reference for the new part
  sourceVendor String?        // Where the part came from

  @@index([eventId])
}

// ──────────────────────────────────────────────────────
// An alert — something that needs attention
// Examples: provenance gap, counterfeit suspect, overdue inspection
// ──────────────────────────────────────────────────────
model Alert {
  id          String    @id @default(cuid())
  componentId String
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  alertType   String    // "provenance_gap", "counterfeit_suspect", "overdue_inspection",
                        // "record_mismatch", "nff_pattern", "life_limit_approaching"
  severity    String    // "info", "warning", "critical"
  title       String
  description String
  status      String    @default("open") // "open", "investigating", "resolved", "dismissed"
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([componentId])
}

// ──────────────────────────────────────────────────────
// An exception — a detected inconsistency or error in the data.
// Found by the automated exception engine scanning across events and documents.
// Examples: cycles going backward, documentation gaps, missing certificates
// ──────────────────────────────────────────────────────
model Exception {
  id              String    @id @default(cuid())
  componentId     String
  component       Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  exceptionType   String    // "serial_number_mismatch", "part_number_mismatch",
                            // "cycle_count_discrepancy", "hour_count_discrepancy",
                            // "documentation_gap", "missing_release_certificate",
                            // "missing_birth_certificate", "date_inconsistency",
                            // "unsigned_document"
  severity        String    // "info", "warning", "critical"
  title           String    // Human-readable title for the exception
  description     String    // Detailed plain-language explanation of what was found
  evidence        Json      // JSON — the specific data points that triggered this
  status          String    @default("open") // "open", "investigating", "resolved", "false_positive"
  detectedAt      DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?

  @@index([componentId])
}

// ──────────────────────────────────────────────────────
// A source document associated with a component
// Legacy docs, CMMs, service bulletins, certificates
// ──────────────────────────────────────────────────────
model Document {
  id            String   @id @default(cuid())
  componentId   String
  component     Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  docType       String    // "cmm", "service_bulletin", "certificate", "legacy_work_order",
                          // "birth_certificate", "8130", "coc"
  title         String
  fileName      String?
  filePath      String?
  extractedText String?   // AI-extracted text from PDF
  aiSummary     String?   // AI-generated summary
  hash          String?   // File hash
  isLegacy      Boolean   @default(false) // Was this digitized from paper?
  createdAt     DateTime  @default(now())

  @@index([componentId])
}


// ══════════════════════════════════════════════════════
// MOBILE CAPTURE SYSTEM — New models for iPhone app + multi-technician support
// Added for AeroVision Capture PoC (Feb 2026)
// ══════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────
// Organization — the repair station or shop
// A shop's info auto-populates into generated compliance documents
// ──────────────────────────────────────────────────────
model Organization {
  id                    String   @id @default(cuid())
  name                  String                          // e.g., "Precision Aerospace MRO"
  faaRepairStationCert  String?                         // FAA Part 145 certificate number
  emailDomain           String?                         // e.g., "silverwingsaviation.com" — auto-join users with matching email
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  phone                 String?
  email                 String?
  agentInstructions     String?                         // Markdown instructions injected into all AI prompts for this org
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relationships
  users           User[]
  captureSessions CaptureSession[]
  measurementSpecs MeasurementSpec[]
  auditLog        AuditLogEntry[]
  inviteCodes     InviteCode[]
  orgDocuments    OrgDocument[]
  inspectionTemplates InspectionTemplate[]
}

// ──────────────────────────────────────────────────────
// InviteCode — lets admins generate codes that new users enter to join an org.
// Codes look like "SLVR-8K2M". Can be limited by usage count or expiration date.
// ──────────────────────────────────────────────────────
model InviteCode {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String    @unique                      // 8-char code like "SLVR-8K2M"
  createdBy      String?                                // userId who generated it
  maxUses        Int?                                   // null = unlimited
  useCount       Int       @default(0)
  expiresAt      DateTime?                              // null = never expires
  status         String    @default("active")           // active, revoked
  createdAt      DateTime  @default(now())

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────
// OrgDocument — internal PDFs uploaded by org members (checklists, SOPs, etc.)
// Scoped to organization — only members of the same org can see these.
// ──────────────────────────────────────────────────────
model OrgDocument {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String                                    // Display name (e.g., "Station Handoff Checklist")
  fileUrl        String                                    // Vercel Blob URL
  fileSizeBytes  Int      @default(0)
  formFieldsJson Json?                                     // Cached extracted form fields (parsed JSON from Gemini)
  uploadedBy     String?                                   // userId who uploaded it
  createdAt      DateTime @default(now())

  // Sessions that selected this document as their target
  captureSessions CaptureSession[]

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────
// CaptureSession — a single capture session from the mobile app
// Created when a technician taps "Start Capture", ended when they tap "Finish"
// ──────────────────────────────────────────────────────
model CaptureSession {
  id              String    @id @default(cuid())
  userId          String
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  componentId     String?                               // Linked after AI identifies the part
  status          String    @default("capturing")       // capturing, processing, documents_generated, submitted, approved, rejected
                                                        // Layer 2 adds: inspecting, reviewing, signed_off
  description     String?
  targetFormType  String?                               // Which FAA form to auto-populate: "8130-3", "337", or "8010-4"
  orgDocumentId   String?                               // Internal form selected for this session (mutually exclusive with targetFormType)
  orgDocument     OrgDocument? @relation(fields: [orgDocumentId], references: [id], onDelete: SetNull)
  expectedSteps   String?                               // Free-text SOP — expected maintenance steps for this session
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Layer 2: CMM-guided inspection fields
  sessionType                 String    @default("capture")   // "capture" (existing flow) or "inspection" (CMM-guided)
  inspectionTemplateId        String?                         // FK to InspectionTemplate — which CMM template guides this inspection
  inspectionTemplate          InspectionTemplate? @relation(fields: [inspectionTemplateId], references: [id], onDelete: SetNull)
  inspectionTemplateVersion   Int?                            // Snapshot of template version at session creation (immutable record)
  configurationVariant        String?                         // Selected P/N variant for this inspection session
  activeInspectionSectionId   String?                         // Which sub-assembly section the tech is currently working on
  workOrderRef                String?                         // Optional work order number, e.g., "WO#359847"
  signedOffById               String?                         // FK to User who signed off on this inspection
  signedOffBy                 User? @relation("inspectionSignOff", fields: [signedOffById], references: [id], onDelete: SetNull)
  signedOffAt                 DateTime?                       // When the inspection was signed off
  signOffNotes                String?                         // Optional notes from sign-off

  // Layer 3: Post-session reconciliation results (matched/unmatched/conflicts summary)
  reconciliationSummary       Json?

  // Relationships
  evidence        CaptureEvidence[]
  documents       CaptureDocument[]
  analysis        SessionAnalysis?
  processingJob   SessionProcessingJob?
  packages        SessionPackage[]
  measurements    Measurement[]
  inspectionProgress  InspectionProgress[]
  inspectionFindings  InspectionFinding[]

  @@index([userId])
  @@index([organizationId])
  @@index([status, startedAt])
  @@index([userId, status, startedAt])
  @@index([organizationId, status, startedAt])
  @@index([sessionType])
}

// ──────────────────────────────────────────────────────
// CaptureEvidence — a piece of evidence captured during a session
// Photos, videos, and audio chunks from the mobile app
// Stored with hash for audit integrity
// ──────────────────────────────────────────────────────
model CaptureEvidence {
  id              String    @id @default(cuid())
  sessionId       String
  session         CaptureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type            String                                // PHOTO, VIDEO, AUDIO_CHUNK
  fileUrl         String                                // URL to file in cloud storage (or local path for PoC)
  fileSize        Int       @default(0)                 // File size in bytes
  fileHash        String?                               // SHA-256 hash for audit integrity
  mimeType        String                                // e.g., "image/jpeg", "video/mp4", "audio/m4a"
  durationSeconds Float?                                // For video and audio
  transcription   String?                               // AI transcription of audio
  aiExtraction    Json?                                 // JSON — AI-extracted data from images (part numbers, text, etc.)
  gpsLatitude     Float?
  gpsLongitude    Float?
  capturedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())

  // Relationships
  videoAnnotations   VideoAnnotation[]
  measurementSources MeasurementSource[]

  @@index([sessionId])
}

// ──────────────────────────────────────────────────────
// VideoAnnotation — timestamped tags from real-time video analysis
// Created by Gemini 2.0 Flash analyzing 2-minute video chunks
// Makes all footage searchable (part numbers spotted, actions observed, tools in use)
// ──────────────────────────────────────────────────────
model VideoAnnotation {
  id          String   @id @default(cuid())
  evidenceId  String
  evidence    CaptureEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  timestamp   Float                                     // Seconds into the video chunk
  tag         String                                    // e.g., "part_number", "action", "tool", "text", "condition"
  description String                                    // e.g., "Torque wrench applied to engine mount bolt"
  confidence  Float    @default(0)                      // 0-1 confidence score
  rawResponse String?                                   // Full AI response for debugging
  createdAt   DateTime @default(now())

  @@index([evidenceId])
}

// ──────────────────────────────────────────────────────
// SessionAnalysis — deep analysis of an entire capture session
// Created by Gemini 2.5 Flash after session ends, with CMM context loaded
// Contains detailed action log, part identification, procedure verification
// ──────────────────────────────────────────────────────
model SessionAnalysis {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         CaptureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actionLog       Json                                  // JSON — timestamped list of actions observed (from video)
  partsIdentified Json                                  // JSON — all part numbers/serials found (fused from all sources)
  procedureSteps  Json                                  // JSON — maintenance steps identified
  anomalies       Json     @default("[]")               // JSON — any concerns or anomalies spotted
  audioTranscript String?                               // Full stitched audio transcript with timestamps
  photoExtractions Json?                                // JSON — per-photo structured extraction data
  confidence      Float    @default(0)                  // 0-1 overall confidence
  verificationSource String?                            // "cmm", "expected_steps", or "ai_inferred"
  modelUsed       String                                // e.g., "gemini-3.1-pro-preview"
  modelsUsed      Json?                                 // JSON — all models used across modalities
  rawResponse     String?                               // Full AI response for debugging
  costEstimate    Float?                                // Estimated API cost in dollars
  processingTime  Int?                                  // Processing time in milliseconds
  createdAt       DateTime @default(now())
}

// ──────────────────────────────────────────────────────
// ComponentManual — CMM (Component Maintenance Manual) PDFs
// Uploaded by admins, linked to part numbers
// Loaded into Gemini's 1M token context window during deep video analysis
// ──────────────────────────────────────────────────────
model ComponentManual {
  id            String   @id @default(cuid())
  partNumber    String                                  // Part number this manual applies to
  title         String                                  // e.g., "HPC-7 Hydraulic Pump CMM Rev. 12"
  fileUrl       String                                  // URL in R2 or local path
  fileSizeBytes Int      @default(0)                    // File size for display
  pageCount     Int?                                    // Number of pages (for context window estimation)
  uploadedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  inspectionTemplates InspectionTemplate[]
}

// ──────────────────────────────────────────────────────
// ReferenceData — simple reference info per part number
// Procedures, limits, intervals, specifications — used as AI context
// during document generation (instead of full CMM PDFs for now)
// ──────────────────────────────────────────────────────
model ReferenceData {
  id          String   @id @default(cuid())
  partNumber  String                                    // Which part this reference applies to
  title       String                                    // e.g., "Overhaul Procedure Summary"
  category    String                                    // "procedure", "limit", "interval", "specification"
  content     String                                    // The actual reference text
  source      String                                    // Where this info came from, e.g., "CMM Rev. 12, Section 5.2"
  createdAt   DateTime @default(now())
}

// ──────────────────────────────────────────────────────
// CaptureDocument — AI-generated compliance documents from capture sessions
// ──────────────────────────────────────────────────────
model CaptureDocument {
  id                  String    @id @default(cuid())
  sessionId           String
  session             CaptureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  documentType        String                            // "8130-3", "337", "8010-4", etc. — extensible
  contentJson         Json                              // Full form field data as JSON
  status              String    @default("draft")       // draft, pending_review, approved, rejected
  confidence          Float     @default(0)             // 0-1 overall AI confidence score
  lowConfidenceFields Json      @default("[]")          // JSON array of field names AI was uncertain about
  generatedAt         DateTime  @default(now())
  reviewedById        String?
  reviewedBy          User? @relation("reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt          DateTime?
  reviewNotes         String?
  evidenceLineage     Json?                             // JSON — maps each field to its evidence source, detail, and confidence (legacy single-source)
  provenanceJson      Json?                             // JSON — multi-source provenance: per-field array of all contributing sources with corroboration levels
  verificationJson    Json?                             // JSON — AI verification results (field-level issues, confidence)
  verifiedAt          DateTime?                         // When the independent AI verification completed
  createdAt           DateTime  @default(now())

  @@index([sessionId])
  @@index([reviewedById])
  @@unique([sessionId, documentType])
}

model SessionProcessingJob {
  id             String    @id @default(cuid())
  sessionId      String    @unique
  session        CaptureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  currentStage   String    @default("queued")
  userFacingState String   @default("Captured")
  queuedAt       DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  lastErrorStage String?
  runnerToken    String?
  leaseExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  stages         SessionProcessingStage[]

  @@index([currentStage])
}

model SessionProcessingStage {
  id            String    @id @default(cuid())
  jobId         String
  job           SessionProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage         String
  status        String    @default("queued")
  attemptCount  Int       @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  lastError     String?
  errorMetadata Json?
  latencyMs     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([jobId, stage])
  @@index([status])
}

model SessionPackage {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  session     CaptureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  packageType String    @default("evidence_bundle_manifest")
  status      String    @default("ready")
  manifestJson Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ══════════════════════════════════════════════════════
// SHIFT + MEASUREMENT SYSTEM — Glasses + Mic integration
// Added for production-ready AeroVision (Mar 2026)
// ══════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────
// MeasurementSpec — predefined measurements required for a workflow
// E.g., "HPC-7 Overhaul" requires 42 specific measurements with tolerances.
// When a shift links to a spec, the system tracks progress and validates each reading.
// ──────────────────────────────────────────────────────
model MeasurementSpec {
  id                  String   @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String                          // e.g., "HPC-7 Overhaul Measurements"
  componentPartNumber String?                         // Which part number this spec applies to
  specItemsJson       Json                            // JSON array of expected measurements (see below)
                                                      // Each item: { parameterName, measurementType, unit,
                                                      //   nominalValue, toleranceLow, toleranceHigh,
                                                      //   required, procedureStep, count }
  status              String   @default("draft")      // draft, active, archived
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@index([componentPartNumber])
}

// ──────────────────────────────────────────────────────
// Measurement — one row per measurement taken during a shift
// This is THE measurement ledger — the structured system of record.
// Each measurement can have multiple sources (audio, video, manual)
// that are cross-referenced for confidence scoring.
// ──────────────────────────────────────────────────────
model Measurement {
  id                  String    @id @default(cuid())
  captureSessionId    String                          // The session this measurement belongs to
  captureSession      CaptureSession @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)
  componentId         String?                         // Which part this measurement is for
  component           Component? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  specItemIndex       Int?                            // Which spec item this fulfills (index into specItemsJson)

  // What was measured
  measurementType     String                          // torque, dimension, pressure, temperature, clearance,
                                                      // runout, endplay, backlash, weight, rpm, resistance
  parameterName       String                          // Human label: "Engine mount bolt torque"
  value               Float                           // The accepted numeric value
  unit                String                          // ft-lbs, in-lbs, N-m, inches, mm, mils, psi, degF, degC, ohms

  // Tolerance (from spec or manually set)
  nominalValue        Float?                          // Expected value from CMM/spec
  toleranceLow        Float?                          // Lower bound
  toleranceHigh       Float?                          // Upper bound
  inTolerance         Boolean?                        // Computed: is value within tolerance?

  // Confidence and corroboration
  confidence          Float     @default(0)           // 0-1 overall confidence
  corroborationLevel  String    @default("single")    // single, corroborated, conflicting
  status              String    @default("pending")   // pending, confirmed, flagged, overridden, out_of_tolerance
  flagReason          String?                         // Why it was flagged (e.g., "audio/video mismatch")
  overrideReason      String?                         // If technician overrode, why
  overriddenBy        String?                         // Technician badge who overrode
  overriddenAt        DateTime?

  // Location in the work
  procedureStep       String?                         // CMM section reference (e.g., "5.2.3")
  taskCardRef         String?                         // Task card / job card reference
  sequenceInShift     Int?                            // Order within the shift

  // Timestamps
  measuredAt          DateTime                        // When the measurement was taken
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Layer 2: direct link from measurement to inspection template item
  inspectionItemId    String?                         // FK to InspectionItem — which template item this measurement fulfills
  inspectionItem      InspectionItem? @relation(fields: [inspectionItemId], references: [id], onDelete: SetNull)

  // Relationships
  sources             MeasurementSource[]
  inspectionProgress  InspectionProgress[]

  @@index([captureSessionId])
  @@index([componentId])
  @@index([measurementType])
  @@index([status])
  @@index([inspectionItemId])
}

// ──────────────────────────────────────────────────────
// MeasurementSource — where each measurement value came from
// A measurement can have multiple sources: audio callout, video frame, manual entry.
// This enables cross-referencing: if audio says "45 ft-lbs" and video shows 45,
// confidence goes up. If they disagree, the measurement gets flagged.
// ──────────────────────────────────────────────────────
model MeasurementSource {
  id                  String    @id @default(cuid())
  measurementId       String
  measurement         Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)
  sourceType          String                          // audio_callout, video_frame, photo_gauge, manual_entry
  value               Float                           // What THIS source reported
  unit                String                          // Unit as extracted
  confidence          Float     @default(0)           // 0-1 source-level confidence
  rawExcerpt          String?                         // Text excerpt: "torque reading 45 foot-pounds"
  timestamp           Float?                          // Seconds into the shift when this was captured

  // Link to evidence (one of these will be set)
  captureEvidenceId   String?                         // Photo, video, or audio chunk evidence
  captureEvidence     CaptureEvidence? @relation(fields: [captureEvidenceId], references: [id], onDelete: SetNull)

  createdAt           DateTime  @default(now())

  @@index([measurementId])
  @@index([captureEvidenceId])
}

// ──────────────────────────────────────────────────────
// AuditLogEntry — immutable log of all system actions
// Required for FAA compliance — who did what, when, to what
// ──────────────────────────────────────────────────────
model AuditLogEntry {
  id              String    @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  userId          String?
  user            User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  action          String                                // "session_started", "evidence_captured", "document_generated",
                                                        // "document_approved", "document_rejected", "technician_created", etc.
  entityType      String?                               // "CaptureSession", "CaptureEvidence", "CaptureDocument", etc.
  entityId        String?                               // ID of the affected record
  metadata        Json?                                 // JSON — additional context
  timestamp       DateTime  @default(now())

  @@index([organizationId])
  @@index([userId])
}

// ──────────────────────────────────────────────────────
// Airworthiness Directives (ADs) — mandatory safety actions
// issued by the FAA or EASA when an unsafe condition exists
// ──────────────────────────────────────────────────────
model AirworthinessDirective {
  id                String    @id @default(cuid())
  adNumber          String    @unique            // e.g., "2024-15-06"
  title             String
  issuer            String    @default("FAA")    // "FAA", "EASA", etc.
  effectiveDate     DateTime
  applicability     String                       // Part numbers or families affected
  complianceAction  String                       // What must be done
  complianceDeadline String?                     // e.g., "Within 500 flight hours"
  isEmergency       Boolean   @default(false)    // Emergency AD = immediate compliance
  supersedes        String?                      // AD number this replaces
  status            String    @default("ACTIVE") // ACTIVE, SUPERSEDED, RESCINDED
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ──────────────────────────────────────────────────────
// Service Bulletins (SBs) — manufacturer recommendations
// for modifications, inspections, or part replacements
// ──────────────────────────────────────────────────────
model ServiceBulletin {
  id                String    @id @default(cuid())
  sbNumber          String    @unique            // e.g., "SB-881700-72-001"
  title             String
  manufacturer      String                       // e.g., "Parker Aerospace"
  issueDate         DateTime
  applicability     String                       // Part numbers or families affected
  category          String    @default("OPTIONAL") // MANDATORY, OPTIONAL, ALERT
  description       String                       // What the SB recommends
  complianceAction  String?                      // What must be done
  relatedAd         String?                      // AD number if mandatory
  status            String    @default("ACTIVE") // ACTIVE, SUPERSEDED, COMPLETED
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ══════════════════════════════════════════════════════
// CMM INSPECTION TEMPLATES — Parse CMM PDFs into structured templates
// that guide technicians through inspections.
// Layer 1: upload, AI extraction, admin review/approval.
// ══════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────
// InspectionTemplate — a parsed CMM document stored as a reusable template.
// Contains hierarchical sections (sub-assemblies) with items (specs, checks, tools).
// Status tracks the extraction pipeline: pending → extracting → review_ready → active.
// ──────────────────────────────────────────────────────
model InspectionTemplate {
  id                      String    @id @default(cuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  componentManualId       String?                         // Optional link to existing ComponentManual record
  componentManual         ComponentManual? @relation(fields: [componentManualId], references: [id], onDelete: SetNull)
  createdById             String
  createdBy               User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  title                   String                          // e.g., "IDG Inspection — Collins Aerospace"
  sourceFileUrl           String                          // Vercel Blob URL of uploaded PDF
  sourceFileName          String                          // Original filename
  revisionDate            DateTime?                       // CMM revision date
  partNumbersCovered      String[]                        // Part numbers this template applies to (for auto-linking)
  status                  String    @default("pending_extraction")
                                                          // pending_extraction, extracting_index, extracting_details,
                                                          // review_ready, active, archived, extraction_failed
  totalPages              Int                             // Total pages in uploaded PDF
  inspectionPages         Int[]                           // Which pages are inspection sheets (empty = all)
  extractionMetadata      Json?                           // Pass 1 index, timestamps, models used, cost
  rawExtractionResponses  Json?                           // Raw AI responses for debugging/re-parsing
  version                 Int       @default(1)

  // Extraction job state (lease-based, modeled on SessionProcessingJob)
  extractionRunnerToken   String?                         // Random token held by the current extraction worker
  extractionLeaseExpiresAt DateTime?                      // Lease expires after 2 minutes
  currentSectionIndex     Int       @default(0)           // Which section is being processed next

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relationships
  sections                InspectionSection[]
  linkedComponents        ComponentInspectionTemplate[]
  captureSessions         CaptureSession[]              // Layer 2: sessions using this template

  @@index([organizationId])
  @@index([status])
  @@index([createdById])
}

// ──────────────────────────────────────────────────────
// InspectionSection — one sub-assembly within a template.
// Each section maps to a figure number in the CMM (e.g., "Figure 816 — Variable Unit").
// Multi-sheet figures are grouped into one section with multiple page references.
// ──────────────────────────────────────────────────────
model InspectionSection {
  id                          String    @id @default(cuid())
  templateId                  String
  template                    InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organizationId              String                      // Denormalized for query performance
  title                       String                      // e.g., "Assembly of End Housing Unit"
  figureNumber                String                      // e.g., "816"
  sheetInfo                   String?                     // e.g., "Sheet 2 of 3"
  pageNumbers                 Int[]                       // Which PDF pages this section spans
  referenceImageUrls          String[]                    // Blob URLs for diagram images (for future use)
  status                      String    @default("pending")
                                                          // pending, extracting, extracted, failed, reviewed
  pageClassification          String?                     // diagram, inspection_text, parts_list, mixed
  configurationApplicability  String[]                    // Empty = all configs; some figures are config-specific
  sortOrder                   Int                         // Display order in the template
  itemCount                   Int       @default(0)       // Denormalized count of items
  extractionConfidence        Float     @default(0)       // 0-1 overall confidence for this section
  rawExtractionResponse       Json?                       // Raw AI response for re-parsing
  pageLinks                   Json?                       // Resolved page-to-section links: [{pageIndex, reason, confidence, referenceText}]
  pass2Progress               Json?                       // Per-page extraction state for resumable Pass 2
  notes                       String?                     // Reviewer annotations

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  // Relationships
  items                       InspectionItem[]
  inspectionFindings          InspectionFinding[]         // Layer 2: findings linked to this section

  @@index([templateId])
  @@index([organizationId])
}

// ──────────────────────────────────────────────────────
// InspectionItem — a single spec, check, or requirement within a section.
// Extracted from CMM diagrams by AI. Each item has a type (torque_spec, visual_check, etc.)
// and stores both imperial and metric values where applicable.
// ──────────────────────────────────────────────────────
model InspectionItem {
  id                          String    @id @default(cuid())
  sectionId                   String
  section                     InspectionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  itemType                    String                      // torque_spec, dimension_check, dimensional_spec,
                                                          // visual_check, procedural_check, safety_wire,
                                                          // tool_requirement, matched_set, general_note,
                                                          // replace_if_disturbed
  itemCallout                 String?                     // Diagram callout number, e.g., "290", "310A"
  partNumber                  String?                     // Actual P/N from IPL if known (nullable, for future IPL integration)
  parameterName               String                      // e.g., "End Housing Bolt Torque"
  specification               String                      // Full human-readable spec, e.g., "51-56 LB-IN (5.8-6.3 N-m)"

  // Parsed numeric values for validation (imperial)
  specValueLow                Float?                      // Parsed low value, e.g., 51
  specValueHigh               Float?                      // Parsed high value, e.g., 56
  specUnit                    String?                     // e.g., "LB-IN"

  // Parsed numeric values (metric)
  specValueLowMetric          Float?                      // e.g., 5.8
  specValueHighMetric         Float?                      // e.g., 6.3
  specUnitMetric              String?                     // e.g., "N-m"

  // References and requirements
  toolsRequired               String[]                    // e.g., ["AGE10037", "BLS-34347"]
  checkReference              String?                     // e.g., "CHECK 23"
  repairReference             String?                     // e.g., "REPAIR 6, 25"
  specialAssemblyRef          String?                     // e.g., "SPECIAL ASSEMBLY FIGURE 823"
  configurationApplicability  String[]                    // Empty = all configs
  sequenceGroup               String?                     // For Layer 3 ordering (nullable, future use)
  notes                       String?                     // Cautions, warnings, special instructions

  // Metadata
  sortOrder                   Int                         // Display order within the section
  confidence                  Float     @default(0)       // 0-1 confidence score
  reviewReason                String?                     // Why this item needs review (null = no review needed)

  // Human correction tracking (for ML eval pipeline)
  humanCorrection             Json?                       // { original: {...}, corrected: {...}, correctionType: "wrong_value"|"missing_item"|"wrong_type"|"spurious_item" }
  correctedAt                 DateTime?                   // When a human corrected this item
  correctedById               String?                     // User who corrected this item

  // Edit tracking
  editedById                  String?                     // User who last edited this item during review
  editedAt                    DateTime?                   // When the item was last manually edited

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  // Layer 2 reverse relations
  measurements                Measurement[]               // Measurements linked to this inspection item
  inspectionProgress          InspectionProgress[]        // Progress records for this item
  inspectionFindings          InspectionFinding[]         // Findings attached to this item

  @@index([sectionId])
}

// ──────────────────────────────────────────────────────
// ComponentInspectionTemplate — join table linking components to their templates.
// Created when a template is approved (auto-linked by matching part numbers).
// Used by Layer 2 to suggest the right template for a work order.
// ──────────────────────────────────────────────────────
model ComponentInspectionTemplate {
  id          String    @id @default(cuid())
  componentId String
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  templateId  String
  template    InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([componentId, templateId])
  @@index([componentId])
  @@index([templateId])
}

// ══════════════════════════════════════════════════════
// LAYER 2: CMM-GUIDED INSPECTION WORKFLOW
// Progress tracking and findings for guided inspection sessions.
// InspectionProgress is thin — values live in Measurement table, not duplicated here.
// ══════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────
// InspectionProgress — tracks completion status for each inspection item in a session.
// The captured VALUE lives in the linked Measurement record (no duplication).
// Status tracks work state, result tracks the outcome.
// ──────────────────────────────────────────────────────
model InspectionProgress {
  id                  String    @id @default(cuid())
  captureSessionId    String
  captureSession      CaptureSession @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)
  inspectionItemId    String
  inspectionItem      InspectionItem @relation(fields: [inspectionItemId], references: [id], onDelete: Cascade)

  status              String    @default("pending")       // pending, done, problem, skipped
  result              String?                             // pass, fail, in_spec, out_of_spec, not_applicable (null when pending)
  measurementId       String?                             // FK to Measurement — THE source of truth for captured values
  measurement         Measurement? @relation(fields: [measurementId], references: [id], onDelete: SetNull)
  notes               String?                             // Inspector notes for this item
  skipReason          String?                             // Required when status is "skipped"

  completedAt         DateTime?                           // When this item was completed
  completedById       String?                             // FK to User who completed this item
  completedBy         User? @relation("progressCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  updatedAt           DateTime  @updatedAt                // Needed for polling endpoint

  @@unique([captureSessionId, inspectionItemId])          // One progress record per item per session
  @@index([captureSessionId, updatedAt])                  // For incremental polling: "what changed since X?"
  @@index([inspectionItemId])
}

// ──────────────────────────────────────────────────────
// InspectionFinding — a non-routine discovery during inspection.
// Mechanics find unexpected issues: damage, corrosion, missing hardware.
// Minimal capture: photo + one-line description + severity.
// ──────────────────────────────────────────────────────
model InspectionFinding {
  id                    String    @id @default(cuid())
  captureSessionId      String
  captureSession        CaptureSession @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)
  inspectionItemId      String?                           // Nullable — finding may not relate to a specific item
  inspectionItem        InspectionItem? @relation(fields: [inspectionItemId], references: [id], onDelete: SetNull)
  inspectionSectionId   String                            // Which section this finding is in
  inspectionSection     InspectionSection @relation(fields: [inspectionSectionId], references: [id], onDelete: Cascade)

  description           String                            // One-line description of the finding
  severity              String    @default("major")       // minor, major, critical
  recommendedAction     String?                           // Optional — can be added later at review time
  photoUrls             String[]                          // Blob URLs for finding photos
  status                String    @default("open")        // open, deferred, resolved

  createdById           String                            // FK to User who created this finding
  createdBy             User @relation("findingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())

  @@index([captureSessionId])
  @@index([inspectionSectionId])
}
